# MintMap environment — copy to `.env` and fill in. Never commit real keys.

# --- AI (server-side) --------------------------------------------------------
# Gemini is the primary provider. Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional model overrides (defaults are sensible).
# GEMINI_MODEL=models/gemini-flash-latest
# GEMINI_STT_MODEL=gemini-flash-latest

# Optional fallback providers (leave blank to disable).
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1

# --- Google sync (client-side, browser) --------------------------------------
# OAuth "Web application" client id from Google Cloud Console. Public/client-safe
# (shipped to the browser). Add your origin (e.g. https://plan.mintyapi.com and
# http://localhost:8080) to the client's "Authorized JavaScript origins".
# Enable the Google Calendar API and Google Drive API for the project.
# Used for Google Calendar 2-way sync and Drive backup (drive.appdata scope).
VITE_GOOGLE_CLIENT_ID=
